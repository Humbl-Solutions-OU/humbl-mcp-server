{
  "name": "@humbl-ai/mcp-advert",
  "version": "1.0.0",
  "description": "MCP server for Humbl.ai advert data — 7 tools for ad research and PPC analysis",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run obfuscate",
    "obfuscate": "node scripts/obfuscate.js",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "prepare": "npm run build"
  },
  "keywords": ["mcp", "model-context-protocol", "humbl", "advert", "ppc", "marketing"],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/humbl.ai.git",
    "directory": "mcp-server"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "javascript-obfuscator": "^4.1.0"
  },
  "bin": {
    "@humbl-ai/mcp-advert": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
